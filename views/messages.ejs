<%- include('partials/header') %>

<div class="messages-container">
    <div class="messages-header">
        <a href="/matches" class="back-link">← Back to Matches</a>
        <h1>💬 Chat with <%= otherUser.username %></h1>
        <% if (typeof isOnline !== 'undefined' && isOnline(otherUser.lastActive)) { %>
            <span class="online-badge">🟢 Online</span>
        <% } else { %>
            <span class="offline-badge">⚪ Last active: <%= formatRelativeTime(otherUser.lastActive) %></span>
        <% } %>
    </div>

    <div class="chat-window">
        <!-- Messages List -->
        <div class="messages-list" id="messagesList">
            <% if (messages && messages.length > 0) { %>
                <% messages.forEach(message => { %>
                    <div class="message <%= message.sender._id.toString() === user._id.toString() ? 'message-sent' : 'message-received' %>">
                        <div class="message-avatar">
                            <%= getAvatarEmoji(message.sender.gender) %>
                        </div>
                        <div class="message-content">
                            <div class="message-bubble">
                                <p><%= message.content %></p>
                            </div>
                            <span class="message-time"><%= formatRelativeTime(message.createdAt) %></span>
                            <% if (message.sender._id.toString() === user._id.toString() && message.isRead) { %>
                                <span class="message-read">✓✓ Read</span>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="no-messages">
                    <p>👋 Start the conversation! Send a friendly message to break the ice.</p>
                </div>
            <% } %>
        </div>

        <!-- Message Form -->
        <form id="messageForm" class="message-form" action="/messages/<%= match._id %>" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="matchId" value="<%= match._id %>">
            
            <div class="message-input-wrapper">
                <textarea 
                    id="messageInput" 
                    name="content" 
                    rows="1" 
                    maxlength="<%= constants.MESSAGE_MAX_LENGTH %>" 
                    placeholder="Type a message..." 
                    required
                ></textarea>
                <button type="submit" class="btn-send">➤</button>
            </div>
            <small><span id="charCount">0</span>/<%= constants.MESSAGE_MAX_LENGTH %></small>
        </form>
    </div>

    <!-- Chat Guidelines -->
    <div class="chat-guidelines">
        <h4>📋 Chat Guidelines</h4>
        <ul>
            <li>Be respectful and kind in all conversations</li>
            <li>Don't share personal contact info too quickly</li>
            <li>Report inappropriate behavior using the report button</li>
            <li>Remember: everyone here is looking for serious relationships</li>
        </ul>
        <button class="btn btn-warning btn-sm" onclick="reportUser('<%= otherUser._id %>')">
            ⚠️ Report <%= otherUser.username %>
        </button>
    </div>
</div>

<script>
// Auto-resize textarea
const messageInput = document.getElementById('messageInput');
const charCount = document.getElementById('charCount');
const messagesList = document.getElementById('messagesList');

if (messageInput) {
    messageInput.addEventListener('input', function() {
        // Resize textarea
        this.style.height = 'auto';
        this.style.height = (this.scrollHeight) + 'px';
        
        // Update character count
        charCount.textContent = this.value.length;
    });
    
    // Submit form on Enter (but allow Shift+Enter for new line)
    messageInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            document.getElementById('messageForm').requestSubmit();
        }
    });
}

// Auto-scroll to bottom on load
if (messagesList) {
    messagesList.scrollTop = messagesList.scrollHeight;
}

// Report user function
async function reportUser(userId) {
    const reason = prompt('Why are you reporting this user? (optional)');
    
    try {
        const response = await fetch(`/user/${userId}/report`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': '<%= csrfToken %>'
            },
            body: JSON.stringify({ reason: reason || 'Inappropriate behavior' })
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('✓ User reported successfully. Thank you for keeping our community safe.');
        } else {
            alert('✗ ' + (data.message || 'Failed to report user'));
        }
    } catch (error) {
        console.error('Report error:', error);
        alert('✗ Failed to report user. Please try again.');
    }
}

// Optional: Auto-refresh messages every 30 seconds
// Uncomment if implementing real-time features
/*
setInterval(async () => {
    try {
        const response = await fetch('/messages/<%= match._id %>');
        const html = await response.text();
        // Parse and update messages list (simplified)
    } catch (error) {
        console.error('Auto-refresh error:', error);
    }
}, 30000);
*/
</script>

<style>
    .messages-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
    }
    .messages-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }
    .messages-header h1 {
        margin: 0;
        color: var(--text-color);
        flex: 1;
    }
    .back-link {
        color: var(--primary-color);
        text-decoration: none;
        font-weight: 500;
    }
    .back-link:hover {
        text-decoration: underline;
    }
    .online-badge, .offline-badge {
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 500;
    }
    .online-badge {
        background: #e8f5e9;
        color: #2e7d32;
    }
    .offline-badge {
        background: #f5f5f5;
        color: var(--text-light);
    }
    .chat-window {
        background: var(--card-background);
        border-radius: var(--border-radius);
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
        height: calc(100vh - 300px);
        min-height: 400px;
        max-height: 600px;
    }
    .messages-list {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .message {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
        max-width: 80%;
    }
    .message-sent {
        margin-left: auto;
        flex-direction: row-reverse;
    }
    .message-avatar {
        font-size: 2rem;
        flex-shrink: 0;
    }
    .message-content {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .message-bubble {
        padding: 0.75rem 1rem;
        border-radius: 18px;
        line-height: 1.4;
    }
    .message-received .message-bubble {
        background: #f0f0f0;
        color: var(--text-color);
        border-bottom-left-radius: 4px;
    }
    .message-sent .message-bubble {
        background: var(--primary-color);
        color: white;
        border-bottom-right-radius: 4px;
    }
    .message-time {
        font-size: 0.75rem;
        color: var(--text-light);
    }
    .message-sent .message-time {
        text-align: right;
    }
    .message-read {
        font-size: 0.7rem;
        color: var(--success-color);
    }
    .no-messages {
        text-align: center;
        padding: 2rem;
        color: var(--text-light);
    }
    .message-form {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border-color);
    }
    .message-input-wrapper {
        display: flex;
        gap: 0.5rem;
        align-items: flex-end;
    }
    .message-input-wrapper textarea {
        flex: 1;
        padding: 0.75rem 1rem;
        border: 2px solid var(--border-color);
        border-radius: 24px;
        resize: none;
        font-family: inherit;
        font-size: 1rem;
        max-height: 120px;
        transition: var(--transition);
    }
    .message-input-wrapper textarea:focus {
        outline: none;
        border-color: var(--primary-color);
    }
    .btn-send {
        background: var(--primary-color);
        color: white;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        font-size: 1.2rem;
        cursor: pointer;
        transition: var(--transition);
        flex-shrink: 0;
    }
    .btn-send:hover {
        background: var(--primary-dark);
        transform: scale(1.05);
    }
    .message-form small {
        display: block;
        text-align: right;
        color: var(--text-light);
        font-size: 0.75rem;
        margin-top: 0.25rem;
    }
    .chat-guidelines {
        background: var(--card-background);
        padding: 1.5rem;
        border-radius: var(--border-radius);
        box-shadow: var(--shadow);
        margin-top: 1.5rem;
    }
    .chat-guidelines h4 {
        margin-bottom: 0.75rem;
        color: var(--text-color);
    }
    .chat-guidelines ul {
        list-style: none;
        padding: 0;
        margin: 0 0 1rem 0;
    }
    .chat-guidelines li {
        padding: 0.25rem 0;
        color: var(--text-light);
        font-size: 0.9rem;
    }
    .btn-sm {
        padding: 0.4rem 0.8rem;
        font-size: 0.85rem;
    }
    @media (max-width: 768px) {
        .messages-container {
            padding: 1rem;
        }
        .chat-window {
            height: calc(100vh - 250px);
        }
        .message {
            max-width: 90%;
        }
    }
</style>

<%- include('partials/footer') %>
