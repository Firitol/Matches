<%- include('partials/header') %>

<div class="stats-container">
    <div class="stats-header">
        <h1>📊 My Statistics</h1>
        <p>Track your activity and engagement on EthioMatch</p>
    </div>

    <!-- Stats Overview -->
    <div class="stats-overview">
        <div class="stat-card primary">
            <div class="stat-icon">💕</div>
            <div class="stat-value"><%= stats.totalMatches || 0 %></div>
            <div class="stat-label">Total Matches</div>
            <div class="stat-change">People you've connected with</div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon">⏳</div>
            <div class="stat-value"><%= stats.pendingMatches || 0 %></div>
            <div class="stat-label">Pending Likes</div>
            <div class="stat-change">Waiting for a response</div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon">💬</div>
            <div class="stat-value"><%= stats.totalMessages || 0 %></div>
            <div class="stat-label">Messages Sent</div>
            <div class="stat-change">Conversations started</div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon">👁️</div>
            <div class="stat-value"><%= stats.profileViews || 0 %></div>
            <div class="stat-label">Profile Views</div>
            <div class="stat-change">Times your profile was viewed</div>
        </div>
    </div>

    <!-- Activity Timeline -->
    <div class="stats-section">
        <h3>📅 Recent Activity</h3>
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-date">Today</div>
                <div class="timeline-content">
                    <strong>Logged in</strong>
                    <span class="timeline-meta">Welcome back!</span>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-date">Yesterday</div>
                <div class="timeline-content">
                    <strong>Updated profile</strong>
                    <span class="timeline-meta">Added new interests</span>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-date">3 days ago</div>
                <div class="timeline-content">
                    <strong>New match!</strong>
                    <span class="timeline-meta">Connected with <%= typeof recentMatch !== 'undefined' && recentMatch ? recentMatch : 'someone' %></span>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-date">1 week ago</div>
                <div class="timeline-content">
                    <strong>Joined EthioMatch</strong>
                    <span class="timeline-meta">Started your journey</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Engagement Tips -->
    <div class="stats-section">
        <h3>💡 How to Improve Your Match Rate</h3>
        <div class="tips-grid">
            <div class="tip-card">
                <div class="tip-icon">📝</div>
                <h4>Complete Your Profile</h4>
                <p>Profiles with bios and interests get 3x more matches.</p>
            </div>
            <div class="tip-card">
                <div class="tip-icon">📸</div>
                <h4>Add a Profile Photo</h4>
                <p>Verified photos increase trust and response rates.</p>
            </div>
            <div class="tip-card">
                <div class="tip-icon">💬</div>
                <h4>Start Conversations</h4>
                <p>Personalized messages get 5x more replies than "Hi".</p>
            </div>
            <div class="tip-card">
                <div class="tip-icon">🔄</div>
                <h4>Stay Active</h4>
                <p>Regular activity keeps your profile visible to others.</p>
            </div>
        </div>
    </div>

    <!-- Premium Features Teaser -->
    <div class="stats-section premium-teaser">
        <h3>🌟 Unlock Premium Insights</h3>
        <p>Upgrade to see who viewed your profile, get read receipts, and more!</p>
        <button class="btn btn-primary" disabled>Coming Soon</button>
        <p class="premium-note">Premium features are being developed. Stay tuned!</p>
    </div>
</div>

<style>
    .stats-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
    }
    .stats-header {
        text-align: center;
        margin-bottom: 2rem;
    }
    .stats-header h1 {
        color: var(--primary-color);
        margin-bottom: 0.5rem;
    }
    .stats-overview {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
    }
    .stat-card {
        background: var(--card-background);
        padding: 1.5rem;
        border-radius: var(--border-radius);
        box-shadow: var(--shadow);
        text-align: center;
        transition: var(--transition);
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-hover);
    }
    .stat-card.primary {
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        color: white;
    }
    .stat-card.primary .stat-label,
    .stat-card.primary .stat-change {
        opacity: 0.9;
    }
    .stat-icon {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }
    .stat-value {
        font-size: 2.5rem;
        font-weight: bold;
        margin-bottom: 0.25rem;
    }
    .stat-card.primary .stat-value {
        color: white;
    }
    .stat-label {
        font-weight: 600;
        color: var(--text-color);
        margin-bottom: 0.25rem;
    }
    .stat-change {
        font-size: 0.85rem;
        color: var(--text-light);
    }
    .stats-section {
        background: var(--card-background);
        padding: 2rem;
        border-radius: var(--border-radius);
        box-shadow: var(--shadow);
        margin-bottom: 2rem;
    }
    .stats-section h3 {
        margin-bottom: 1.5rem;
        color: var(--text-color);
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 0.5rem;
    }
    .timeline {
        position: relative;
        padding-left: 2rem;
    }
    .timeline::before {
        content: '';
        position: absolute;
        left: 0.5rem;
        top: 1rem;
        bottom: 1rem;
        width: 2px;
        background: var(--border-color);
    }
    .timeline-item {
        position: relative;
        padding-bottom: 1.5rem;
    }
    .timeline-item::before {
        content: '';
        position: absolute;
        left: -1.35rem;
        top: 0.25rem;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--primary-color);
        border: 3px solid white;
        box-shadow: 0 0 0 2px var(--primary-color);
    }
    .timeline-date {
        font-weight: 600;
        color: var(--primary-color);
        margin-bottom: 0.25rem;
    }
    .timeline-content strong {
        display: block;
        color: var(--text-color);
        margin-bottom: 0.25rem;
    }
    .timeline-meta {
        font-size: 0.9rem;
        color: var(--text-light);
    }
    .tips-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
    }
    .tip-card {
        text-align: center;
        padding: 1.5rem;
        background: var(--background-color);
        border-radius: var(--border-radius);
    }
    .tip-icon {
        font-size: 2rem;
        margin-bottom: 0.75rem;
    }
    .tip-card h4 {
        margin-bottom: 0.5rem;
        color: var(--text-color);
    }
    .tip-card p {
        color: var(--text-light);
        font-size: 0.9rem;
        line-height: 1.4;
    }
    .premium-teaser {
        text-align: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }
    .premium-teaser h3 {
        color: white;
        border-bottom-color: rgba(255,255,255,0.3);
    }
    .premium-teaser p {
        margin-bottom: 1.5rem;
        opacity: 0.95;
    }
    .premium-teaser .btn {
        background: white;
        color: #667eea;
        margin-bottom: 0.75rem;
    }
    .premium-note {
        font-size: 0.85rem;
        opacity: 0.8;
    }
    @media (max-width: 768px) {
        .stats-overview {
            grid-template-columns: repeat(2, 1fr);
        }
        .stats-container {
            padding: 1rem;
        }
    }
</style>

<%- include('partials/footer') %>
