<!-- views/dashboard.ejs -->
<%- include('partials/header', { activePage: 'dashboard' }) %>

<div class="dashboard-container">
  
  <!-- Welcome Header -->
  <section class="dashboard-header">
    <div class="welcome-banner">
      <h1>Welcome, <%= user.username %>! 👋</h1>
      <p class="subtitle">Find your meaningful connection today</p>
    </div>
    
    <!-- Quick Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-value"><%= stats.matchCount %></span>
        <span class="stat-label">Matches</span>
      </div>
      <div class="stat-card">
        <span class="stat-value"><%= stats.likeCount %></span>
        <span class="stat-label">Pending Likes</span>
      </div>
      <div class="stat-card">
        <span class="stat-value"><%= stats.potentialCount %></span>
        <span class="stat-label">New Profiles</span>
      </div>
      <div class="stat-card">
        <span class="stat-value"><%= user.isVerified ? '✅' : '⏳' %></span>
        <span class="stat-label"><%= user.isVerified ? 'Verified' : 'Pending' %></span>
      </div>
    </div>
  </section>

  <!-- My Matches Section -->
  <section class="dashboard-section">
    <div class="section-header">
      <h2>💕 My Matches</h2>
      <a href="/matches" class="view-all">View All →</a>
    </div>
    
    <% if (matches && matches.length > 0) { %>
      <div class="matches-grid" id="matches-grid">
        <% matches.slice(0, 4).forEach(match => { %>
          <div class="match-card" id="match-<%= match.id %>">
            <div class="match-avatar">
              <img src="<%= match.profileImage || '/images/default-avatar.png' %>" 
                   alt="<%= match.username %>"
                   onerror="this.src='/images/default-avatar.png'">
            </div>
            <div class="match-info">
              <h3><%= match.username %>, <%= match.age %></h3>
              <p class="location">📍 <%= match.location %></p>
              <div class="match-actions">
                <a href="/messages/<%= match.id %>" class="btn btn-primary btn-sm">Message</a>
                <a href="/user/<%= match.id %>" class="btn btn-secondary btn-sm">View Profile</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <p>✨ No matches yet. Keep exploring to find your person!</p>
        <a href="#potential" class="btn btn-primary">Browse Profiles</a>
      </div>
    <% } %>
  </section>

  <!-- Potential Matches Section -->
  <section class="dashboard-section" id="potential">
    <div class="section-header">
      <h2>🔍 Discover New Profiles</h2>
      <span class="subtitle">People who match your preferences</span>
    </div>
    
    <% if (potentialMatches && potentialMatches.length > 0) { %>
      <div class="profiles-grid">
        <% potentialMatches.forEach(profile => { %>
          <div class="profile-card" id="profile-<%= profile.id %>">
            <div class="profile-header">
              <div class="profile-avatar">
                <img src="<%= profile.profileImage || '/images/default-avatar.png' %>" 
                     alt="<%= profile.username %>"
                     onerror="this.src='/images/default-avatar.png'">
              </div>
              <span class="profile-age"><%= profile.age %></span>
            </div>
            
            <div class="profile-body">
              <h3><%= profile.username %></h3>
              <p class="profile-location">📍 <%= profile.location %></p>
              <p class="profile-bio"><%= truncateText(profile.bio, 80) %></p>
              
              <% if (profile.interests && profile.interests.length > 0) { %>
                <div class="profile-interests">
                  <% profile.interests.slice(0, 3).forEach(interest => { %>
                    <span class="interest-tag"><%= interest %></span>
                  <% }) %>
                  <% if (profile.interests.length > 3) { %>
                    <span class="interest-tag">+<%= profile.interests.length - 3 %> more</span>
                  <% } %>
                </div>
              <% } %>
            </div>
            
            <div class="profile-actions">
              <button onclick="likeUser('<%= profile.id %>')" class="btn btn-like">❤️ Like</button>
              <button onclick="passUser('<%= profile.id %>')" class="btn btn-pass">❌ Pass</button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <p>🎉 You've seen everyone! Check back later for new profiles.</p>
      </div>
    <% } %>
  </section>

  <!-- Quick Actions -->
  <section class="dashboard-section">
    <h2>⚡ Quick Actions</h2>
    <div class="actions-grid">
      <a href="/profile" class="action-card">
        <span class="action-icon">👤</span>
        <div>
          <strong>Edit Profile</strong>
          <small>Update your info & photos</small>
        </div>
      </a>
      <a href="/matches" class="action-card">
        <span class="action-icon">💬</span>
        <div>
          <strong>Messages</strong>
          <small>Chat with your matches</small>
        </div>
      </a>
      <a href="/profile" class="action-card">
        <span class="action-icon">⚙️</span>
        <div>
          <strong>Settings</strong>
          <small>Privacy & preferences</small>
        </div>
      </a>
      <a href="/logout" class="action-card action-logout">
        <span class="action-icon">🚪</span>
        <div>
          <strong>Logout</strong>
          <small>Sign out securely</small>
        </div>
      </a>
    </div>
  </section>

</div>

<!-- Styles (inline or move to CSS file) -->
<style>
/* ... keep your original CSS as is ... */
</style>

<!-- Like/Pass Scripts -->
<script>
  const socket = typeof window.io === 'function' ? window.io() : null;
  if (socket) {
    socket.emit('join', '<%= user.id %>');

    socket.on('newMatch', (matchData) => {
    alert(`🎉 New Match! You matched with ${matchData.username}`);
    const matchesGrid = document.getElementById('matches-grid');
    if(matchesGrid) {
      const newCard = document.createElement('div');
      newCard.className = 'match-card';
      newCard.innerHTML = `
        <div class="match-avatar">
          <img src="${matchData.profileImage || '/images/default-avatar.png'}" alt="${matchData.username}" onerror="this.src='/images/default-avatar.png'">
        </div>
        <div class="match-info">
          <h3>${matchData.username}, ${matchData.age}</h3>
          <p class="location">📍 ${matchData.location}</p>
          <div class="match-actions">
            <a href="/messages/${matchData.id}" class="btn btn-primary btn-sm">Message</a>
            <a href="/user/${matchData.id}" class="btn btn-secondary btn-sm">View Profile</a>
          </div>
        </div>
      `;
      matchesGrid.prepend(newCard);
    }
    });
  }

  async function likeUser(userId) {
    const btn = event.target;
    btn.disabled = true;
    btn.textContent = 'Sending...';
    try {
      const res = await fetch('/like/' + userId, { method: 'POST', headers: {'Content-Type':'application/json'}});
      const data = await res.json();
      if(data.success){
        const card = btn.closest('.profile-card');
        if(data.isMatch){
          alert("🎉 It's a match! Start chatting now.");
          window.location.href = '/matches';
        } else {
          alert('❤️ Like sent!');
          if(card) card.remove();
        }
      } else {
        alert('❌ Failed to send like.');
      }
    } catch(err){
      console.error(err);
      alert('❌ Failed to send like.');
    } finally {
      btn.disabled = false;
      btn.textContent = '❤️ Like';
    }
  }

  function passUser(userId){
    const card = event.target.closest('.profile-card');
    if(card){
      card.style.transition = 'all 0.3s ease';
      card.style.transform = 'translateX(100%) rotate(15deg)';
      card.style.opacity = '0';
      setTimeout(()=>card.remove(),300);
    }
  }
</script>

<%- include('partials/footer') %>
