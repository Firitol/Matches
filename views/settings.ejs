<%- include('partials/header') %>

<div class="settings-container">
    <div class="settings-header">
        <h1>⚙️ Account Settings</h1>
        <p>Manage your preferences and account options</p>
    </div>

    <div class="settings-grid">
        <!-- Notification Preferences -->
        <div class="settings-card">
            <h3>🔔 Notification Preferences</h3>
            <p>Choose how you'd like to be notified about activity on your account.</p>
            
            <form action="/settings/notifications" method="POST" class="settings-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                
                <label class="checkbox-label">
                    <input type="checkbox" name="emailNotifications" <%= user.emailNotifications !== false ? 'checked' : '' %>>
                    <span>Email notifications</span>
                    <small>Receive emails about new matches, messages, and account updates</small>
                </label>
                
                <label class="checkbox-label">
                    <input type="checkbox" name="pushNotifications" <%= user.pushNotifications !== false ? 'checked' : '' %>>
                    <span>Browser notifications</span>
                    <small>Get real-time alerts when you receive new messages</small>
                </label>
                
                <button type="submit" class="btn btn-primary">Save Preferences</button>
            </form>
        </div>

        <!-- Privacy Settings -->
        <div class="settings-card">
            <h3>🔒 Privacy Settings</h3>
            <p>Control who can see your profile and activity.</p>
            
            <div class="privacy-options">
                <div class="privacy-option">
                    <strong>Profile Visibility</strong>
                    <p>Your profile is visible to all verified EthioMatch members.</p>
                    <span class="badge badge-info">Public to members</span>
                </div>
                
                <div class="privacy-option">
                    <strong>Last Active</strong>
                    <p>Show when you were last online to your matches.</p>
                    <span class="badge badge-success">Visible to matches</span>
                </div>
                
                <div class="privacy-option">
                    <strong>Location</strong>
                    <p>Your city is shown to help find nearby matches.</p>
                    <span class="badge badge-warning"><%= user.location %></span>
                </div>
            </div>
            
            <p class="settings-note">
                <strong>Note:</strong> We never share your exact address or personal contact info.
            </p>
        </div>

        <!-- Account Information -->
        <div class="settings-card">
            <h3>📋 Account Information</h3>
            
            <div class="info-row">
                <span class="info-label">Username</span>
                <span class="info-value"><%= user.username %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Email</span>
                <span class="info-value"><%= user.email %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Member Since</span>
                <span class="info-value"><%= formatDate(user.createdAt) %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Account Status</span>
                <span class="info-value">
                    <span class="badge badge-success">Active</span>
                </span>
            </div>
            
            <a href="/profile" class="btn btn-secondary">Edit Profile Details</a>
        </div>

        <!-- Data & Export -->
        <div class="settings-card">
            <h3>📦 Your Data</h3>
            <p>Manage your personal data and download your information.</p>
            
            <div class="data-actions">
                <button class="btn btn-outline" disabled>
                    📥 Download My Data
                    <small>(Coming soon)</small>
                </button>
                
                <button class="btn btn-outline" disabled>
                    🗑️ Request Data Deletion
                    <small>(Use Delete Account instead)</small>
                </button>
            </div>
            
            <p class="settings-note">
                We take your privacy seriously. Your data is encrypted and never sold to third parties.
            </p>
        </div>

        <!-- Connected Apps -->
        <div class="settings-card">
            <h3>🔗 Connected Apps</h3>
            <p>Manage third-party apps connected to your EthioMatch account.</p>
            
            <div class="empty-state">
                <p>No connected apps</p>
                <small>For security, we don't currently support third-party app connections.</small>
            </div>
        </div>

        <!-- Session Management -->
        <div class="settings-card">
            <h3>🔐 Active Sessions</h3>
            <p>Manage devices where you're currently logged in.</p>
            
            <div class="session-item current">
                <div class="session-info">
                    <strong>Current Session</strong>
                    <span class="session-meta">This device • Active now</span>
                </div>
                <span class="badge badge-success">Active</span>
            </div>
            
            <p class="settings-note">
                To log out of all devices, use the Logout button in the navigation menu.
            </p>
        </div>
    </div>

    <!-- Help Section -->
    <div class="settings-help">
        <h3>❓ Need Help?</h3>
        <div class="help-links">
            <a href="#" class="help-link">📚 Safety Tips & Guidelines</a>
            <a href="#" class="help-link">📝 Terms of Service</a>
            <a href="#" class="help-link">🔐 Privacy Policy</a>
            <a href="#" class="help-link">✉️ Contact Support</a>
        </div>
    </div>
</div>

<style>
    .settings-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem;
    }
    .settings-header {
        text-align: center;
        margin-bottom: 2rem;
    }
    .settings-header h1 {
        color: var(--primary-color);
        margin-bottom: 0.5rem;
    }
    .settings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    .settings-card {
        background: var(--card-background);
        padding: 1.5rem;
        border-radius: var(--border-radius);
        box-shadow: var(--shadow);
    }
    .settings-card h3 {
        margin-bottom: 1rem;
        color: var(--text-color);
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 0.5rem;
    }
    .settings-card > p {
        color: var(--text-light);
        margin-bottom: 1.5rem;
        line-height: 1.5;
    }
    .settings-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .checkbox-label {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        cursor: pointer;
        padding: 0.5rem;
        border-radius: var(--border-radius);
        transition: var(--transition);
    }
    .checkbox-label:hover {
        background: var(--background-color);
    }
    .checkbox-label input {
        width: auto;
        margin: 0;
    }
    .checkbox-label small {
        color: var(--text-light);
        font-size: 0.85rem;
        margin-left: 1.5rem;
    }
    .privacy-options {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .privacy-option {
        padding: 1rem;
        background: var(--background-color);
        border-radius: var(--border-radius);
    }
    .privacy-option strong {
        display: block;
        margin-bottom: 0.25rem;
        color: var(--text-color);
    }
    .privacy-option p {
        margin: 0 0 0.5rem 0;
        color: var(--text-light);
        font-size: 0.9rem;
    }
    .badge {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .badge-info { background: #e3f2fd; color: #1976d2; }
    .badge-success { background: #e8f5e9; color: #2e7d32; }
    .badge-warning { background: #fff3e0; color: #ef6c00; }
    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--border-color);
    }
    .info-row:last-child {
        border-bottom: none;
    }
    .info-label {
        color: var(--text-light);
    }
    .info-value {
        font-weight: 500;
        color: var(--text-color);
    }
    .data-actions {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    .btn-outline {
        background: transparent;
        border: 2px solid var(--border-color);
        color: var(--text-color);
        padding: 0.75rem 1rem;
        border-radius: var(--border-radius);
        cursor: not-allowed;
        opacity: 0.6;
        text-align: left;
    }
    .btn-outline small {
        display: block;
        font-size: 0.8rem;
        color: var(--text-light);
    }
    .empty-state {
        text-align: center;
        padding: 2rem 1rem;
        color: var(--text-light);
    }
    .session-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        background: var(--background-color);
        border-radius: var(--border-radius);
        margin-bottom: 0.75rem;
    }
    .session-item.current {
        border: 2px solid var(--primary-color);
    }
    .session-info strong {
        display: block;
        color: var(--text-color);
    }
    .session-meta {
        font-size: 0.85rem;
        color: var(--text-light);
    }
    .settings-note {
        font-size: 0.85rem;
        color: var(--text-light);
        line-height: 1.5;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-color);
    }
    .settings-help {
        background: var(--card-background);
        padding: 2rem;
        border-radius: var(--border-radius);
        box-shadow: var(--shadow);
        text-align: center;
    }
    .settings-help h3 {
        margin-bottom: 1rem;
        color: var(--text-color);
    }
    .help-links {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: center;
    }
    .help-link {
        color: var(--primary-color);
        text-decoration: none;
        font-weight: 500;
        transition: var(--transition);
    }
    .help-link:hover {
        text-decoration: underline;
    }
    @media (max-width: 768px) {
        .settings-grid {
            grid-template-columns: 1fr;
        }
        .settings-container {
            padding: 1rem;
        }
    }
</style>

<%- include('partials/footer') %>
