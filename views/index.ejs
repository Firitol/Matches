

<section class="hero">
    <div class="hero-content">
        <h1>🇪🇹 Et-Match</h1>
        <p class="hero-tagline"><%= typeof tagline !== 'undefined' ? tagline : 'Find serious relationships with Ethiopians worldwide' %></p>
        <p class="hero-subtitle">Connect with like-minded individuals looking for meaningful, long-term relationships.</p>
        
        <div class="hero-actions">
            <a href="/register" class="btn btn-primary btn-large">Join Free Today</a>
            <a href="/login" class="btn btn-secondary btn-large">Already a Member? Login</a>
        </div>
        
        <div class="hero-features">
            <div class="feature">
                <span class="feature-icon">✅</span>
                <span>100% Free to Join</span>
            </div>
            <div class="feature">
                <span class="feature-icon">🔒</span>
                <span>Verified Profiles</span>
            </div>
            <div class="feature">
                <span class="feature-icon">❤️</span>
                <span>Serious Relationships Only</span>
            </div>
            <div class="feature">
                <span class="feature-icon">🇪🇹</span>
                <span>Ethiopian Community</span>
            </div>
        </div>
    </div>
</section>

<section class="how-it-works">
    <h2>How EthioMatch Works</h2>
    <div class="steps-grid">
        <div class="step-card">
            <div class="step-number">1</div>
            <h3>Create Your Profile</h3>
            <p>Sign up in minutes and tell us about yourself, your values, and what you're looking for.</p>
        </div>
        <div class="step-card">
            <div class="step-number">2</div>
            <h3>Discover Matches</h3>
            <p>Browse compatible profiles based on your preferences, location, and interests.</p>
        </div>
        <div class="step-card">
            <div class="step-number">3</div>
            <h3>Connect & Chat</h3>
            <p>When you both like each other, start a conversation and build a real connection.</p>
        </div>
        <div class="step-card">
            <div class="step-number">4</div>
            <h3>Find Your Person</h3>
            <p>Take your relationship offline and build something meaningful together.</p>
        </div>
    </div>
</section>

<section class="testimonials">
    <h2>Success Stories</h2>
    <div class="testimonials-grid">
        <div class="testimonial-card">
            <p>"I was skeptical about online dating, but EthioMatch helped me find my fiancé. We're getting married next year!"</p>
            <div class="testimonial-author">— Selam, Addis Ababa</div>
        </div>
        <div class="testimonial-card">
            <p>"Finally, a dating app that focuses on serious relationships. Met my partner here and we've been together for 2 years."</p>
            <div class="testimonial-author">— Dawit, Diaspora</div>
        </div>
        <div class="testimonial-card">
            <p>"The verification process made me feel safe. I appreciate that everyone here is looking for something real."</p>
            <div class="testimonial-author">— Hanna, Bahir Dar</div>
        </div>
    </div>
</section>

<section class="cta-section">
    <h2>Ready to Find Your Match?</h2>
    <p>Join thousands of Ethiopians looking for serious relationships.</p>
    <a href="/register" class="btn btn-primary btn-large">Create Free Account</a>
    <p class="cta-note">⚠️ Must be 18+ to join. By signing up, you agree to our Terms of Service.</p>
</section>

<style>
    .hero {
        background: linear-gradient(135deg, #d32f2f 0%, #b71c1c 100%);
        color: white;
        padding: 4rem 2rem;
        text-align: center;
    }
    .hero h1 {
        font-size: 3rem;
        margin-bottom: 1rem;
    }
    .hero-tagline {
        font-size: 1.5rem;
        margin-bottom: 1rem;
        opacity: 0.95;
    }
    .hero-subtitle {
        font-size: 1.1rem;
        margin-bottom: 2rem;
        opacity: 0.9;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }
    .hero-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 3rem;
    }
    .btn-large {
        padding: 1rem 2rem;
        font-size: 1.1rem;
    }
    .hero-features {
        display: flex;
        gap: 2rem;
        justify-content: center;
        flex-wrap: wrap;
        max-width: 800px;
        margin: 0 auto;
    }
    .feature {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
    }
    .feature-icon {
        font-size: 1.2rem;
    }
    .how-it-works, .testimonials, .cta-section {
        padding: 4rem 2rem;
        text-align: center;
    }
    .how-it-works h2, .testimonials h2, .cta-section h2 {
        margin-bottom: 2rem;
        color: var(--primary-color);
    }
    .steps-grid, .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }
    .step-card, .testimonial-card {
        background: var(--card-background);
        padding: 2rem;
        border-radius: var(--border-radius);
        box-shadow: var(--shadow);
        text-align: left;
    }
    .step-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background: var(--primary-color);
        color: white;
        border-radius: 50%;
        font-weight: bold;
        margin-bottom: 1rem;
    }
    .step-card h3 {
        margin-bottom: 0.5rem;
        color: var(--text-color);
    }
    .step-card p, .testimonial-card p {
        color: var(--text-light);
        line-height: 1.5;
    }
    .testimonial-author {
        margin-top: 1rem;
        font-weight: 600;
        color: var(--primary-color);
    }
    .cta-section {
        background: var(--background-color);
    }
    .cta-note {
        margin-top: 1rem;
        color: var(--text-light);
        font-size: 0.9rem;
    }
    @media (max-width: 768px) {
        .hero h1 { font-size: 2rem; }
        .hero-tagline { font-size: 1.2rem; }
        .hero-actions { flex-direction: column; align-items: center; }
        .btn-large { width: 100%; max-width: 300px; }
    }
</style>

<%- include('partials/footer') %>
