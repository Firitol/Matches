
<section class="hero">
    <div class="hero-content">
        <h1>🇪🇹 Et-Match</h1>

        <p class="hero-tagline">
        <%= typeof tagline !== 'undefined' 
            ? tagline 
            : 'Find serious relationships with Ethiopians worldwide' %>
        </p>

        <p class="hero-subtitle">
        Connect with like-minded individuals looking for meaningful,
        long-term relationships.
        </p>

        <div class="hero-actions">
            <a href="/register" class="btn btn-primary btn-large">
            Join Free Today
            </a>

            <a href="/login" class="btn btn-secondary btn-large">
            Already a Member? Login
            </a>
        </div>

        <div class="hero-features">

            <div class="feature">
                <span class="feature-icon">✅</span>
                <span>100% Free to Join</span>
            </div>

            <div class="feature">
                <span class="feature-icon">🔒</span>
                <span>Verified Profiles</span>
            </div>

            <div class="feature">
                <span class="feature-icon">❤️</span>
                <span>Serious Relationships Only</span>
            </div>

            <div class="feature">
                <span class="feature-icon">🇪🇹</span>
                <span>Ethiopian Community</span>
            </div>

        </div>
    </div>
</section>


<section class="how-it-works">

<h2>How Et-Match Works</h2>

<div class="steps-grid">

<div class="step-card">
<div class="step-number">1</div>
<h3>Create Your Profile</h3>
<p>Sign up in minutes and tell us about yourself.</p>
</div>

<div class="step-card">
<div class="step-number">2</div>
<h3>Discover Matches</h3>
<p>Browse compatible profiles easily.</p>
</div>

<div class="step-card">
<div class="step-number">3</div>
<h3>Connect & Chat</h3>
<p>Start conversations and build connections.</p>
</div>

<div class="step-card">
<div class="step-number">4</div>
<h3>Find Your Person</h3>
<p>Build a meaningful relationship.</p>
</div>

</div>

</section>


<section class="cta-section">

<h2>Ready to Find Your Match?</h2>

<p>Join thousands of Ethiopians today.</p>

<a href="/register" class="btn btn-primary btn-large">
Create Free Account
</a>

<p class="cta-note">
⚠️ Must be 18+ to join.
</p>

</section>

<%- include('partials/footer') %>
