<!-- views/chat.ejs -->
<%- include('partials/header') %>

<div class="chat-container" style="max-width:800px;margin:0 auto;padding:0;height:calc(100vh - 70px);display:flex;flex-direction:column;background:#fff">
  
  <!-- Chat Header -->
  <div style="display:flex;align-items:center;padding:1rem;background:#fff;border-bottom:1px solid #e0e0e0;position:sticky;top:0;z-index:100">
    <a href="/messages" style="margin-right:1rem;color:#666;text-decoration:none;font-size:1.25rem">←</a>
    
    <div style="width:40px;height:40px;border-radius:50%;overflow:hidden;background:#e0e0e0;margin-right:0.75rem;display:flex;align-items:center;justify-content:center;flex-shrink:0">
      <% if (match.otherUser.profileImage && match.otherUser.profileImage.startsWith('http')) { %>
        <img src="<%= match.otherUser.profileImage %>" alt="<%= match.otherUser.username %>" style="width:100%;height:100%;object-fit:cover">
      <% } else { %>
        <span style="font-size:1.25rem"><%= typeof getAvatarEmoji === 'function' ? getAvatarEmoji(match.otherUser.username) : '👤' %></span>
      <% } %>
    </div>
    
    <div style="flex:1">
      <h2 style="margin:0;font-size:1rem;font-weight:600;color:#1A1A2E"><%= match.otherUser.username %></h2>
      <small style="color:#22c55e">● Online</small>
    </div>
  </div>
  
  <!-- Messages Area -->
  <div id="messagesList" style="flex:1;overflow-y:auto;padding:1rem;background:#f5f5f5;display:flex;flex-direction:column;gap:0.5rem">
    
    <% if (messages && messages.length > 0) { %>
      <% messages.forEach(msg => { %>
        <div style="display:flex;<%= msg.senderId === currentUser.id ? 'justify-content:flex-end' : 'justify-content:flex-start' %>">
          <div style="max-width:70%;padding:0.5rem 0.75rem;border-radius:8px;<%= msg.senderId === currentUser.id ? 'background:#26EAED;color:#1A1A2E' : 'background:#fff;color:#1A1A2E;box-shadow:0 1px 2px rgba(0,0,0,0.1)' %>">
            
            <!-- Media Display -->
            <% if (msg.mediaType === 'image') { %>
              <div style="margin-bottom:0.25rem">
                <img src="<%= msg.mediaUrl %>" alt="Image" style="max-width:100%;border-radius:4px;cursor:pointer" onclick="openImageModal('<%= msg.mediaUrl %>')">
              </div>
            <% } else if (msg.mediaType === 'video') { %>
              <div style="margin-bottom:0.25rem">
                <video src="<%= msg.mediaUrl %>" controls style="max-width:100%;border-radius:4px"></video>
              </div>
            <% } %>
            
            <!-- Text Content -->
            <% if (msg.content) { %>
              <p style="margin:0;font-size:0.95rem;line-height:1.4"><%= msg.content %></p>
            <% } %>
            
            <!-- Timestamp -->
            <small style="display:block;margin-top:0.25rem;font-size:0.7rem;opacity:0.7;text-align:right">
              <%= typeof formatDate === 'function' ? formatDate(msg.createdAt) : '' %>
            </small>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div style="text-align:center;color:#666;padding:2rem;margin:auto">
        <p>👋 Say hello to <%= match.otherUser.username %>!</p>
      </div>
    <% } %>
    
  </div>
  
  <!-- Message Input Area -->
  <form id="messageForm" style="display:flex;gap:0.5rem;padding:0.75rem;background:#fff;border-top:1px solid #e0e0e0">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    
    <!-- Media Upload Button -->
    <label style="display:flex;align-items:center;justify-content:center;width:40px;height:40px;background:#f0f0f0;border-radius:20px;cursor:pointer" title="Send photo">
      📷
      <input type="file" id="mediaInput" name="media" accept="image/*,video/*" style="display:none" onchange="sendMedia()">
    </label>
    
    <!-- Text Input -->
    <input type="text" id="messageInput" name="content" placeholder="Type a message..." 
           style="flex:1;padding:0.5rem 1rem;border:1px solid #e0e0e0;border-radius:20px;outline:none;font-size:0.95rem"
           autocomplete="off">
    
    <!-- Send Button -->
    <button type="submit" id="sendBtn" style="padding:0.5rem 1.25rem;background:#26EAED;color:#1A1A2E;border:none;border-radius:20px;font-weight:600;cursor:pointer;font-size:0.95rem">
      Send
    </button>
  </form>
  
</div>

<!-- Image Modal -->
<div id="imageModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.9);z-index:1000;align-items:center;justify-content:center" onclick="closeImageModal()">
  <img id="modalImage" src="" alt="Full size" style="max-width:90%;max-height:90%">
  <button onclick="closeImageModal()" style="position:absolute;top:20px;right:20px;background:white;color:black;border:none;padding:0.5rem 1rem;border-radius:4px;cursor:pointer">✕ Close</button>
</div>

<!-- Chat JavaScript -->
<script>
const matchId = '<%= match.id %>';
const messagesList = document.getElementById('messagesList');
const messageForm = document.getElementById('messageForm');
const messageInput = document.getElementById('messageInput');
const mediaInput = document.getElementById('mediaInput');
const sendBtn = document.getElementById('sendBtn');

// Auto-scroll to bottom
function scrollToBottom() {
  if (messagesList) messagesList.scrollTop = messagesList.scrollHeight;
}
scrollToBottom();

// Send text message
if (messageForm) {
  messageForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const content = messageInput.value.trim();
    if (!content) return;
    
    messageInput.disabled = true;
    if (sendBtn) sendBtn.disabled = true;
    sendBtn.textContent = '...';
    
    try {
      const response = await fetch('/messages/' + matchId + '/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: content })
      });
      
      const data = await response.json();
      
      if (data.success) {
        addMessageToUI(data);
        messageInput.value = '';
      } else {
        alert('Failed: ' + (data.message || 'Unknown error'));
      }
    } catch (error) {
      console.error('Send error:', error);
      alert('Failed to send message');
    } finally {
      messageInput.disabled = false;
      if (sendBtn) {
        sendBtn.disabled = false;
        sendBtn.textContent = 'Send';
      }
      messageInput.focus();
    }
  });
}

// Send media message
async function sendMedia() {
  const file = mediaInput.files[0];
  if (!file) return;
  
  if (file.size > 10 * 1024 * 1024) {
    alert('File too large (max 10MB)');
    mediaInput.value = '';
    return;
  }
  
  if (sendBtn) sendBtn.disabled = true;
  mediaInput.disabled = true;
  
  try {
    const formData = new FormData();
    formData.append('media', file);
    formData.append('uploadType', 'message');
    
    const response = await fetch('/messages/' + matchId + '/send-media', {
      method: 'POST',
      body: formData
    });
    
    const data = await response.json();
    
    if (data.success) {
      addMessageToUI(data);
    } else {
      alert('Failed: ' + (data.message || 'Unknown error'));
    }
  } catch (error) {
    console.error('Media send error:', error);
    alert('Failed to send media');
  } finally {
    if (sendBtn) sendBtn.disabled = false;
    mediaInput.disabled = false;
    mediaInput.value = '';
  }
}

// Add message to UI
function addMessageToUI(msg) {
  const msgDiv = document.createElement('div');
  msgDiv.style.cssText = 'display:flex;justify-content:flex-end';
  
  let mediaHtml = '';
  if (msg.mediaType === 'image') {
    mediaHtml = '<div style="margin-bottom:0.25rem"><img src="' + msg.mediaUrl + '" style="max-width:100%;border-radius:4px;cursor:pointer" onclick="openImageModal(\'' + msg.mediaUrl + '\')"></div>';
  } else if (msg.mediaType === 'video') {
    mediaHtml = '<div style="margin-bottom:0.25rem"><video src="' + msg.mediaUrl + '" controls style="max-width:100%;border-radius:4px"></video></div>';
  }
  
  msgDiv.innerHTML = '<div style="max-width:70%;padding:0.5rem 0.75rem;border-radius:8px;background:#26EAED;color:#1A1A2E">' +
    mediaHtml +
    (msg.content ? '<p style="margin:0;font-size:0.95rem;line-height:1.4">' + msg.content.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</p>' : '') +
    '<small style="display:block;margin-top:0.25rem;font-size:0.7rem;opacity:0.7;text-align:right">Just now</small>' +
    '</div>';
  
  if (messagesList) {
    messagesList.appendChild(msgDiv);
    scrollToBottom();
  }
}

// Open image modal
function openImageModal(imageUrl) {
  document.getElementById('modalImage').src = imageUrl;
  document.getElementById('imageModal').style.display = 'flex';
}

// Close image modal
function closeImageModal() {
  document.getElementById('imageModal').style.display = 'none';
}

// Enter key to send
if (messageInput) {
  messageInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (messageForm) messageForm.requestSubmit();
    }
  });
}

// Close modal with Escape
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeImageModal();
});
</script>

<%- include('partials/footer') %>
