<!-- views/premium.ejs -->
<%- include('partials/header', { activePage: 'premium' }) %>

<div class="premium-container" style="max-width:1200px;margin:2rem auto;padding:0 1rem">
  
  <div style="text-align:center;margin-bottom:3rem">
    <h1 style="margin:0 0 1rem 0;color:#1A1A2E;font-size:2.5rem">💎 Upgrade to Premium</h1>
    <p style="margin:0;color:#6B7280;font-size:1.1rem">Unlock exclusive features and find love faster</p>
  </div>
  
  <!-- Premium Plans -->
  <h2 style="text-align:center;margin-bottom:2rem;color:#1A1A2E">Choose Your Plan</h2>
  
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;margin-bottom:3rem">
    <% Object.keys(plans).forEach(function(planKey) {
      var plan = plans[planKey];
    %>
      <div style="background:#fff;border:2px solid <%= planKey === 'premium' ? '#26EAED' : '#e0e0e0' %>;border-radius:12px;padding:2rem;position:relative">
        
        <% if (planKey === 'premium') { %>
          <div style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#26EAED;color:#1A1A2E;padding:0.25rem 1rem;border-radius:20px;font-weight:600;font-size:0.875rem">MOST POPULAR</div>
        <% } %>
        
        <div style="text-align:center;margin-bottom:1.5rem">
          <h3 style="margin:0 0 0.5rem 0;color:#1A1A2E;font-size:1.5rem"><%= plan.name %></h3>
          <div style="font-size:2.5rem;font-weight:700;color:#26EAED">
            <%= plan.price === 0 ? 'Free' : '$' + (plan.price / 100) %>
            <% if (plan.price > 0) { %><span style="font-size:1rem;color:#6B7280">/month</span><% } %>
          </div>
        </div>
        
        <ul style="list-style:none;padding:0;margin:0 0 2rem 0">
          <% plan.features.forEach(function(feature) { %>
            <li style="padding:0.5rem 0;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;gap:0.5rem">
              <span style="color:#22c55e">✓</span>
              <span style="color:#374151"><%= feature %></span>
            </li>
          <% }); %>
        </ul>
        
        <% if (planKey === 'free') { %>
          <button disabled style="width:100%;padding:1rem;background:#e0e0e0;color:#6B7280;border:none;border-radius:8px;font-weight:600;cursor:not-allowed">
            Current Plan
          </button>
        <% } else { %>
          <button onclick="startCheckout('<%= planKey %>')" style="width:100%;padding:1rem;background:<%= planKey === 'premium' ? '#26EAED' : '#1A1A2E' %>;color:<%= planKey === 'premium' ? '#1A1A2E' : '#fff' %>;border:none;border-radius:8px;font-weight:600;cursor:pointer">
            <%= userSubscription && userSubscription.planType === planKey ? 'Current Plan' : 'Upgrade Now' %>
          </button>
        <% } %>
        
      </div>
    <% }); %>
  </div>
  
  <!-- Token Packages -->
  <h2 style="text-align:center;margin-bottom:2rem;color:#1A1A2E">🪙 Buy Message Tokens</h2>
  
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:3rem">
    <% Object.keys(tokenPackages).forEach(function(amount) {
      var pkg = tokenPackages[amount];
    %>
      <div style="background:#fff;border:2px solid #e0e0e0;border-radius:12px;padding:1.5rem;text-align:center">
        <div style="font-size:2rem;font-weight:700;color:#26EAED;margin-bottom:0.5rem"><%= pkg.name %></div>
        <div style="font-size:1.5rem;font-weight:600;color:#1A1A2E;margin-bottom:1rem">$<%= pkg.price / 100 %></div>
        <button onclick="buyTokens(<%= amount %>)" style="width:100%;padding:0.75rem;background:#1A1A2E;color:#fff;border:none;border-radius:8px;font-weight:600;cursor:pointer">
          Purchase
        </button>
      </div>
    <% }); %>
  </div>
  
</div>

<script>
async function startCheckout(planType) {
  try {
    const response = await fetch('/payment/create-checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ planType: planType })
    });
    
    const data = await response.json();
    
    if (data.success && data.url) {
      window.location.href = data.url;
    } else {
      alert('Failed: ' + (data.message || 'Unknown error'));
    }
  } catch (error) {
    console.error('Checkout error:', error);
    alert('Failed to start checkout');
  }
}

async function buyTokens(amount) {
  try {
    const response = await fetch('/payment/create-checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tokenAmount: amount })
    });
    
    const data = await response.json();
    
    if (data.success && data.url) {
      window.location.href = data.url;
    } else {
      alert('Failed: ' + (data.message || 'Unknown error'));
    }
  } catch (error) {
    console.error('Token purchase error:', error);
    alert('Failed to purchase tokens');
  }
}
</script>

<%- include('partials/footer') %>
