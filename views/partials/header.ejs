<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %><%= appName %></title>
  
  <!-- ============================================ -->
  <!-- 📱 PWA META TAGS (ADD THIS SECTION) -->
  <!-- ============================================ -->
  <meta name="theme-color" content="#26EAED">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="EthioMatch">
  <link rel="apple-touch-icon" href="/icons/icon-192x192.png">
  <link rel="manifest" href="/manifest.json">
  <link rel="icon" type="image/png" href="/icons/icon-192x192.png">
  <link rel="shortcut icon" href="/favicon.ico">
  
  <!-- Service Worker Registration -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then((registration) => {
            console.log('SW registered:', registration.scope);
          })
          .catch((error) => {
            console.log('SW registration failed:', error);
          });
      });
    }
  </script>
  <!-- ============================================ -->
  <!-- END PWA META TAGS -->
  <!-- ============================================ -->
  
  <link rel="stylesheet" href="/styles.css">
  <style>
    /* Add any PWA-specific styles here */
  </style>
</head>
<body>
  <nav style="background:#1A1A2E;color:white;padding:1rem;position:sticky;top:0;z-index:100">
    <div style="max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;align-items:center">
      <a href="/" style="color:#26EAED;text-decoration:none;font-size:1.5rem;font-weight:700">🇪🇹 EthioMatch</a>
      
      <div style="display:flex;gap:1rem">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/dashboard" style="color:white;text-decoration:none">Dashboard</a>
          <a href="/messages" style="color:white;text-decoration:none">Messages</a>
          <a href="/profile" style="color:white;text-decoration:none">Profile</a>
          <a href="/logout" style="color:white;text-decoration:none">Logout</a>
        <% } else { %>
          <a href="/login" style="color:white;text-decoration:none">Login</a>
          <a href="/register" style="color:white;text-decoration:none">Register</a>
        <% } %>
      </div>
    </div>
  </nav>
  
  <main>
